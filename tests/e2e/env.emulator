# Copy of minimal Firebase config for local emulators (no production data).
# Merged with .env.local when present. Use the same project id as: npx firebase emulators:start --project <id>
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-tsa.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-tsa
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-tsa.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:e2e
# Default E2E user (Auth emulator)
TSA_E2E_EMAIL=e2e@demo-tsa.local
TSA_E2E_PASSWORD=e2e-password-123456
